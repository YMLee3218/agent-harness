# Workspace .gitignore — artifacts excluded from downstream projects
*.state.json.XXXXXX
*.md.XXXXXX
*.lock

# Stray harness plan.md (belongs at harness root, not workspace) — never commit
/plan.md

# Tool caches — never committed
.ruff_cache/
__pycache__/
.mypy_cache/
.pytest_cache/

# User-local Claude Code overrides (contain personal paths/tokens — never commit)
.claude/settings.local.json

# Claude Code runtime worktrees — ephemeral, never committed
worktrees/
