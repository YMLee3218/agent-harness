{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/.ssh/**",
        "~/.aws/**",
        "~/.config/gcloud/**",
        "~/.kube/config",
        "**/.env",
        "**/.env.*"
      ]
    }
  },
  "env": {
    "PHASE_GATE_STRICT": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add src/**)",
      "Bash(git add tests/**)",
      "Bash(git add docs/**)",
      "Bash(git add plans/**)",
      "Bash(git add features/**)",
      "Bash(git add domain/**)",
      "Bash(git add CLAUDE.md)",
      "Bash(git checkout -b feature/*)",
      "Bash(git commit -m \"test(red): *\")",
      "Bash(git commit -m \"test(green): *\")",
      "Bash(git commit -m \"fix(test): *\")",
      "Bash(git commit -m \"chore(test): *\")",
      "Bash(git commit -m \"feat(*): *\")",
      "Bash(git commit -m \"refactor(*): *\")",
      "Bash(git commit -m \"fix(*): *\")",
      "Bash(git commit -m \"chore(init): *\")",
      "Bash(awk *)",
      "Bash(mise *)",
      "Bash(uv *)",
      "Bash(python --version)",
      "Bash(node --version)",
      "Bash(bash $CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh *)",
      "Bash(git merge --no-ff *)",
      "Bash(git merge --abort)",
      "Bash(git rev-parse *)",
      "Bash(git show-ref *)",
      "Bash(git checkout feature/*)",
      "Bash(mkdir -p *)",
      "Bash(gh pr view *)",
      "Bash(gh pr create *)",
      "Bash(git stash *)",
      "Bash(git worktree *)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/config)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(git commit * --no-verify*)",
      "Bash(git commit --no-verify*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * --force)",
      "Bash(git push * --force *)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Bash(git push * +*)",
      "Bash(git push -f)",
      "Bash(git push --force)",
      "Bash(git clean -f*)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/statusline.sh\""
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".venv", ".cache"]
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude <noreply@anthropic.com>"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/phase-gate.sh\" write"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/pretooluse-bash.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/phase-gate.sh\" prompt"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/post-edit-lint.sh\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/post-edit-failure.sh\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "critic-spec|critic-test|critic-code",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-critic-start",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "critic-spec|critic-test|critic-code",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-verdict"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-task-created"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-task-completed"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-permission-denied",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" flush-before-compact"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" log-post-compact"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" context"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" gc-events",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" flush-on-end",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/stop-check.sh\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-stopfail"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7-plugin@context7-marketplace": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context7-marketplace": {
      "source": {
        "source": "github",
        "repo": "upstash/context7"
      }
    }
  }
}
