{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enabled": false
  },
  "permissions": {
    "allow": [
      "Bash(pwd)",
      "Bash(ls *)",
      "Bash(rg *)",
      "Bash(git *)",
      "Bash(git commit *)",
      "Bash(awk *)",
      "Bash(python --version)",
      "Bash(node --version)",
      "Bash(bash $CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh *)",
      "Bash(bash $CLAUDE_PROJECT_DIR/.claude/scripts/run-critic-loop.sh *)",
      "Bash(bash $CLAUDE_PROJECT_DIR/.claude/scripts/run-dev-cycle.sh *)",
      "Bash(bash $CLAUDE_PROJECT_DIR/.claude/scripts/run-integration.sh *)",
      "Bash(mkdir -p *)",
      "Bash(gh auth status)",
      "Bash(gh pr view *)",
      "Bash(gh pr create *)",
      "Bash(sed *)",
      "Bash(grep *)",
      "Bash(test *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/config)",
      "Read(**/.env)",
      "Bash(git commit * --no-verify*)",
      "Bash(git commit --no-verify*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * --force)",
      "Bash(git push * --force *)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Bash(git push * +*)",
      "Bash(git push -f)",
      "Bash(git push --force)",
      "Bash(git clean -f*)",
      "Bash(git reset --hard *)",
      "Bash(git reset --hard)",
      "Write(**/plans/*.state/**)",
      "Edit(**/plans/*.state/**)",
      "MultiEdit(**/plans/*.state/**)",
      "NotebookEdit(**/plans/*.state/**)",
      "Bash(mv plans/*.md *)",
      "Bash(git checkout * plans/*.md*)",
      "Bash(git restore plans/*.md*)",
      "Bash(git restore plans/*)",
      "Bash(git stash*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/statusline.sh\""
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".venv", ".cache"]
  },
  "attribution": {
    "commit": ""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/phase-gate.sh\" write"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/pretooluse-bash.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "critic-spec|critic-test|critic-code|critic-feature|critic-cross",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLAN_CAPABILITY=harness bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-verdict-guarded"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLAN_CAPABILITY=harness bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" record-task-completed"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/preflight.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" context"
          },
          {
            "type": "command",
            "command": "CLAUDE_PLAN_CAPABILITY=harness bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/plan-file.sh\" gc-events",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/stop-check.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7-plugin@context7-marketplace": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "context7-marketplace": {
      "source": {
        "source": "github",
        "repo": "upstash/context7"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  }
}
